source "https://rubygems.org"

# Jekyll + just-the-docs for GitHub Pages. Matches the stack pinned
# by github/pages-gem so `gh-pages` build servers pick it up cleanly
# without us vendoring a whole Ruby app.

gem "jekyll", "~> 4.3"
gem "just-the-docs", "~> 0.10"

group :jekyll_plugins do
  gem "jekyll-remote-theme", "~> 0.4"
  gem "jekyll-seo-tag", "~> 2.8"
  gem "jekyll-include-cache", "~> 0.2"
end

# Windows and JRuby does not include zoneinfo files; bundling
# tzinfo-data is cheap insurance on those platforms.
platforms :mingw, :x64_mingw, :mswin, :jruby do
  gem "tzinfo", ">= 1", "< 3"
  gem "tzinfo-data"
end
