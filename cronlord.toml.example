## CronLord configuration. Every key has a safe default; this file is
## optional. Environment variables override keys here (CRONLORD_HOST,
## CRONLORD_PORT, CRONLORD_DATA, CRONLORD_DB, CRONLORD_LOG_DIR,
## CRONLORD_ADMIN_TOKEN).

[server]
host = "127.0.0.1"
port = 7070

## Uncomment to require Authorization: Bearer <token> on /api/*.
## Generate one with: openssl rand -hex 32
# admin_token = "replace-me-with-a-long-random-string"

## GitHub OAuth login. When configured, the web UI requires a GitHub login.
## The API (/api/*) is unaffected — it still uses admin_token.
## Generate a session_secret with: openssl rand -hex 32
## Create an OAuth App at: github.com/settings/developers
## Callback URL: http://HOST:PORT/auth/github/callback
## Override with CRONLORD_SESSION_SECRET, CRONLORD_GITHUB_CLIENT_ID,
## CRONLORD_GITHUB_CLIENT_SECRET.
# [server]
# session_secret = "replace-me-with-openssl-rand-hex-32"

# [github]
# client_id     = "your-github-oauth-app-client-id"
# client_secret = "your-github-oauth-app-client-secret"

## GitHub integration. Controls both the webhook trigger and the job-sync feature.
## Override any key with CRONLORD_GITHUB_* env vars.
# [github]
# webhook_secret = "replace-me-with-a-long-random-string"   # for POST /webhooks/github

## Job-sync: fetch [[jobs]] from a remote TOML file and upsert into the DB.
## Run `cronlord github sync` or POST /api/github/sync to trigger.
# repo      = "owner/repo"          # required for sync
# branch    = "main"
# path      = "cronlord.toml"       # path within the repo
# token     = "ghp_..."             # PAT; omit for public repos
# auto_sync = false                 # not yet implemented; reserved

[storage]
## Single directory that holds the SQLite DB and per-run logs.
data_dir = "/var/lib/cronlord"
# db_path  = "/var/lib/cronlord/cronlord.db"
# log_dir  = "/var/lib/cronlord/logs"

## Declarative job entries. Jobs defined here are re-upserted at boot and
## tagged with source = "toml" - the UI lets you see them but deletes are
## reversible (they come back next boot). Use the UI or API for ephemeral
## jobs.

# [[jobs]]
# id       = "heartbeat"
# name     = "Heartbeat"
# schedule = "*/1 * * * *"
# command  = "date -u"
# kind     = "shell"
# enabled  = true

# [[jobs]]
# id       = "daily-backup"
# name     = "Nightly DB dump"
# schedule = "0 3 * * *"
# command  = "/usr/local/bin/backup.sh"
# kind     = "shell"
# timeout_sec = 1800
